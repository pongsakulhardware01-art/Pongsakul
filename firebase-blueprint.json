{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "Represents an employee in the organization",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the employee" },
        "employeeCode": { "type": "string", "description": "Short code/ID for employee display" },
        "firstName": { "type": "string", "description": "Employee first name" },
        "lastName": { "type": "string", "description": "Employee last name" },
        "nickname": { "type": "string", "description": "Employee nickname" },
        "position": { "type": "string", "description": "Role/job position" },
        "department": { "type": "string", "description": "Department name" },
        "phone": { "type": "string", "description": "Phone contact number" },
        "email": { "type": "string", "description": "Email address" },
        "isActive": { "type": "boolean", "description": "Whether employee is currently active" },
        "joinDate": { "type": "string", "description": "Employment start date" }
      },
      "required": ["id", "employeeCode", "firstName", "lastName", "position", "department", "isActive"]
    },
    "HolidayLeave": {
      "title": "HolidayLeave",
      "description": "Represents a holiday or leave record for an employee",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the leave/holiday" },
        "employeeId": { "type": "string", "description": "References Employee.id or 'all'" },
        "startDate": { "type": "string", "description": "Start date in format YYYY-MM-DD" },
        "endDate": { "type": "string", "description": "End date in format YYYY-MM-DD" },
        "type": { "type": "string", "enum": ["vacation", "sick", "personal", "public_holiday", "special_leave", "other"], "description": "Type of holiday/leave" },
        "title": { "type": "string", "description": "The reason or name of the leave" },
        "notes": { "type": "string", "description": "Optional notes or details" },
        "durationDays": { "type": "integer", "description": "Number of days off" }
      },
      "required": ["id", "employeeId", "startDate", "endDate", "type", "title", "durationDays"]
    },
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "Global settings for the system",
      "type": "object",
      "properties": {
        "companyName": { "type": "string", "description": "Name of the company/store" },
        "weekendType": { "type": "string", "description": "Weekend days configuration (e.g. sat-sun)" }
      },
      "required": ["companyName", "weekendType"]
    }
  },
  "firestore": {
    "employees/{employeeId}": {
      "schema": "Employee",
      "description": "Store employees list"
    },
    "holidays/{holidayId}": {
      "schema": "HolidayLeave",
      "description": "Store holiday and leave calendar details"
    },
    "settings/{settingId}": {
      "schema": "SystemSettings",
      "description": "Store global company and system settings"
    }
  }
}
